name: Fetch Release Attachments

on:
  schedule:
    - cron: '0 0 * * *'  # Run daily at midnight UTC
  workflow_dispatch:  # Allow manual triggering

jobs:
  fetch-attachments:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v2

      - name: Set up Python
        uses: actions/setup-python@v2
        with:
          python-version: '3.x'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install requests

      - name: Fetch and organize attachments
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          ORGANIZATION: ${{ secrets.ORGANIZATION_NAME }}
        run: |
          import os
          import requests
          import base64

          def get_repositories():
              url = f"https://api.github.com/orgs/{os.environ['ORGANIZATION']}/repos"
              headers = {
                  "Authorization": f"token {os.environ['GITHUB_TOKEN']}",
                  "Accept": "application/vnd.github.v3+json"
              }
              response = requests.get(url, headers=headers)
              return [repo['name'] for repo in response.json()]

          def get_releases(repo):
              url = f"https://api.github.com/repos/{os.environ['ORGANIZATION']}/{repo}/releases"
              headers = {
                  "Authorization": f"token {os.environ['GITHUB_TOKEN']}",
                  "Accept": "application/vnd.github.v3+json"
              }
              response = requests.get(url, headers=headers)
              return response.json()

          def download_asset(url, path):
              headers = {
                  "Authorization": f"token {os.environ['GITHUB_TOKEN']}",
                  "Accept": "application/octet-stream"
              }
              response = requests.get(url, headers=headers)
              os.makedirs(os.path.dirname(path), exist_ok=True)
              with open(path, 'wb') as f:
                  f.write(response.content)

          repos = get_repositories()
          for repo in repos:
              releases = get_releases(repo)
              for release in releases:
                  for asset in release['assets']:
                      asset_path = f"fw/{repo}/{release['tag_name']}/{asset['name']}"
                      download_asset(asset['url'], asset_path)
                      print(f"Downloaded: {asset_path}")

      - name: Commit and push changes
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add .
          git diff --quiet && git diff --staged --quiet || (git commit -m "Update release attachments" && git push)
          